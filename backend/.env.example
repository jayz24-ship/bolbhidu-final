NODE_ENV=development
PORT=8080
CLIENT_ORIGIN=http://localhost:3000

MONGO_URI=mongodb://127.0.0.1:27017/bolbhidu

JWT_SECRET=change_me
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=yyy
GOOGLE_CALLBACK_URL=http://localhost:8080/auth/google/callback

CLOUDINARY_CLOUD_NAME=your_cloud
CLOUDINARY_API_KEY=123
CLOUDINARY_API_SECRET=abc

# AI Validation - Pick at least ONE (see AI_SETUP_GUIDE.md for details)
# Option 1: Google Gemini (RECOMMENDED - Free, 60 req/min)
GEMINI_API_KEY=AIzaSy...your_key_here

# Option 2: Groq (Fast & Free, 30 req/min)
# GROQ_API_KEY=gsk_...your_key_here

# Option 3: HuggingFace (Free, 1000 req/day)
# HUGGINGFACE_API_KEY=hf_...your_key_here

# Option 4: OpenAI (Paid only - for backward compatibility)
# OPENAI_API_KEY=sk-proj-xxx

ISSUE_ESCALATION_SCORE=50
FEED_RADIUS_KM=25
MAX_UPLOAD_MB=50
